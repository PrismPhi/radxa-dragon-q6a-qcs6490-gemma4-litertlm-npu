+class Gemma4KvCacheBinder {
+ public:
+  static absl::Status BindNextState(
+      absl::flat_hash_map<absl::string_view, ::litert::TensorBuffer>& outputs,
+      absl::flat_hash_map<absl::string_view, ::litert::TensorBuffer>&
+          prefill_inputs,
+      absl::flat_hash_map<absl::string_view, ::litert::TensorBuffer>&
+          decode_inputs,
+      absl::flat_hash_map<absl::string_view, ::litert::TensorBuffer>*
+          next_prefill_inputs = nullptr,
+      bool emit_marker = true) {
+    int copied = 0;
+    for (auto& [name, output_buffer] : outputs) {
+      if (!Q6AIsKvCacheBufferName(name)) {
+        continue;
+      }
+      RETURN_IF_ERROR(CopyToInput(output_buffer, prefill_inputs, name));
+      if (next_prefill_inputs != nullptr &&
+          next_prefill_inputs != &prefill_inputs) {
+        RETURN_IF_ERROR(CopyToInput(output_buffer, *next_prefill_inputs, name));
+      }
+      RETURN_IF_ERROR(CopyToInput(output_buffer, decode_inputs, name));
+      ++copied;
+    }
+
+    if (copied == 0) {
+      return absl::FailedPreconditionError(
+          "Gemma4KvCacheBinder: no kv_cache_* buffers copied");
+    }
+
+    if (emit_marker) {
+      ABSL_LOG(ERROR) << "Q6A_GEMMA4_KV_BIND_OK buffers=" << copied;
+    }
+    return absl::OkStatus();
+  }
+
+  static absl::Status BindDecodeState(
+      absl::flat_hash_map<absl::string_view, ::litert::TensorBuffer>& outputs,
+      absl::flat_hash_map<absl::string_view, ::litert::TensorBuffer>&
+          decode_inputs) {
+    int copied = 0;
+    for (auto& [name, output_buffer] : outputs) {
+      if (!Q6AIsKvCacheBufferName(name)) {
+        continue;
+      }
+      RETURN_IF_ERROR(CopyToInput(output_buffer, decode_inputs, name));
+      ++copied;
+    }
+    if (copied == 0) {
+      return absl::FailedPreconditionError(
+          "Gemma4KvCacheBinder: no decode kv_cache_* buffers copied");
+    }
+    return absl::OkStatus();
+  }
+
+ private:
+  static absl::Status CopyToInput(
+      ::litert::TensorBuffer& output_buffer,
+      absl::flat_hash_map<absl::string_view, ::litert::TensorBuffer>& inputs,
+      absl::string_view name) {
+    if (!inputs.contains(name)) {
+      return absl::FailedPreconditionError(
+          absl::StrCat("Gemma4KvCacheBinder: input KV buffer missing: ", name));
+    }
+    return Q6ACopyTensorBuffer(output_buffer, inputs[name]);
+  }
+};
