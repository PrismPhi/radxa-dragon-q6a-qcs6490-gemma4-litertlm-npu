+absl::StatusOr<uint32_t> Q6AGetDirectContextCapacity(
+    const litert::Model* transformer_model) {
+  auto decode_signature = transformer_model->FindSignature(kDecodeSignature);
+  if (!decode_signature ||
+      !ContainsSignatureName(decode_signature->InputNames(), "mask")) {
+    return absl::FailedPreconditionError(
+        "Gemma4 Direct requires decode mask to determine context capacity.");
+  }
+  LITERT_ASSIGN_OR_RETURN(auto mask_tensor,
+                          decode_signature->InputTensor("mask"));
+  LITERT_ASSIGN_OR_RETURN(auto mask_type, mask_tensor.RankedTensorType());
+  const auto dimensions = mask_type.Layout().Dimensions();
+  if (dimensions.empty() || dimensions.back() <= 0) {
+    return absl::FailedPreconditionError(
+        "Gemma4 Direct decode mask has invalid context capacity.");
+  }
+  return static_cast<uint32_t>(dimensions.back());
+}
