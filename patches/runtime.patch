+          LlmSignatures::kVerifyLlm, llm_inference_context.verify_input_buffers,
+          llm_inference_context.verify_output_buffers);
+      if (!verify_result) {
+        ABSL_LOG(ERROR) << "Q6A_OFFICIAL_VERIFY_NPU_FAIL invoke: "
+                        << verify_result.Error().Message();
+        RET_CHECK(verify_result)
+            << "Q6A_OFFICIAL_VERIFY_NPU_FAIL invoke: "
+            << verify_result.Error().Message();
+      }
+      ABSL_LOG(ERROR) << "Q6A_OFFICIAL_VERIFY_NPU_INVOKE_OK";
+      ABSL_LOG(ERROR) << "Q6A_NPU_VERIFY_INVOKE_OK";
+
+      int outputs_read = 0;
+      for (auto& [output_name, output_buffer] :
+           llm_inference_context.verify_output_buffers) {
+        LITERT_ASSIGN_OR_RETURN(auto output_type, output_buffer.TensorType());
+        (void)output_type;
+        LITERT_ASSIGN_OR_RETURN(
+            auto output_lock,
+            ::litert::TensorBufferScopedLock::Create(
+                output_buffer, ::litert::TensorBuffer::LockMode::kRead));
+        (void)output_lock;
+        ++outputs_read;
+      }
+      ABSL_LOG(ERROR) << "Q6A_OFFICIAL_VERIFY_OUTPUT_READ_OK outputs_read="
+                      << outputs_read;
+      ABSL_LOG(ERROR) << "Q6A_NPU_VERIFY_ACCEPT_READ_OK outputs_read="
+                      << outputs_read;
+    }
+
+    auto result = llm_compiled_model.Run(
+        LlmSignatures::kPrefillLlm,
+        llm_inference_context.prefill_input_buffers,
+        llm_inference_context.prefill_output_buffers);
+    RET_CHECK(result) << "Q6A_GEMMA4_DIRECT_PREFILL_FAILED: "
+                      << result.Error().Message();
+
+    result = llm_compiled_model.Run(
+        LlmSignatures::kDecodeLlm, llm_inference_context.decode_input_buffers,
+        llm_inference_context.decode_output_buffers);
+    RET_CHECK(result) << "Q6A_GEMMA4_DIRECT_DECODE_FAILED: "
+                      << result.Error().Message();
+
+    LITERT_ASSIGN_OR_RETURN(auto embedder_lrt_model,
+                            resources.GetTFLiteModel(ModelType::kTfLiteEmbedder));
+    LITERT_ASSIGN_OR_RETURN(
+        auto embedder_per_layer_lrt_model,
+        resources.GetTFLiteModel(ModelType::kTfLitePerLayerEmbedder));
+
+    LITERT_ASSIGN_OR_RETURN(auto cpu_options,
+                            CreateLiteRtCpuOptions(direct_executor_settings));
+
+    LITERT_ASSIGN_OR_RETURN(
+        CompiledModel direct_embedder_compiled_model,
+        CompiledModel::Create(env, embedder_lrt_model->Get(), cpu_options));
+    LITERT_ASSIGN_OR_RETURN(
+        CompiledModel direct_per_layer_compiled_model,
+        CompiledModel::Create(env, embedder_per_layer_lrt_model->Get(),
+                              cpu_options));
+
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_embedder_prefill_inputs;
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_embedder_prefill_outputs;
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_embedder_decode_inputs;
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_embedder_decode_outputs;
+
+    LITERT_ASSIGN_OR_RETURN(
+        direct_embedder_prefill_inputs[EmbedderSignatures::kEmbedderInput],
+        direct_embedder_compiled_model.CreateInputBuffer(
+            "embedder", "token_ids"));
+    LITERT_ASSIGN_OR_RETURN(
+        direct_embedder_prefill_outputs[EmbedderSignatures::kEmbedderOutput],
+        direct_embedder_compiled_model.CreateOutputBuffer(
+            "embedder", "embeddings"));
+
+    LITERT_ASSIGN_OR_RETURN(
+        direct_embedder_decode_inputs[EmbedderSignatures::kEmbedderInput],
+        direct_embedder_compiled_model.CreateInputBuffer(
+            "embedder", "token_ids"));
+    LITERT_ASSIGN_OR_RETURN(
+        direct_embedder_decode_outputs[EmbedderSignatures::kEmbedderOutput],
+        direct_embedder_compiled_model.CreateOutputBuffer(
+            "embedder", "embeddings"));
+
+    EmbedderContext direct_embedder_context(
+        std::move(direct_embedder_compiled_model),
+        std::move(direct_embedder_prefill_inputs),
+        std::move(direct_embedder_prefill_outputs),
+        std::move(direct_embedder_decode_inputs),
+        std::move(direct_embedder_decode_outputs));
+
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_per_layer_prefill_inputs;
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_per_layer_prefill_outputs;
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_per_layer_decode_inputs;
+    absl::flat_hash_map<absl::string_view, TensorBuffer>
+        direct_per_layer_decode_outputs;
+
+    LITERT_ASSIGN_OR_RETURN(
+        direct_per_layer_prefill_inputs
+            [EmbedderPerLayerSignatures::kEmbedderInput],
+        direct_per_layer_compiled_model.CreateInputBuffer(
+            "per_layer_embedder", "token_ids"));
+    LITERT_ASSIGN_OR_RETURN(
+        direct_per_layer_prefill_outputs
+            [EmbedderPerLayerSignatures::kEmbedderOutput],
+        direct_per_layer_compiled_model.CreateOutputBuffer(
+            "per_layer_embedder", "embeddings"));
+
+    LITERT_ASSIGN_OR_RETURN(
+        direct_per_layer_decode_inputs
+            [EmbedderPerLayerSignatures::kEmbedderInput],
+        direct_per_layer_compiled_model.CreateInputBuffer(
+            "per_layer_embedder", "token_ids"));
+    LITERT_ASSIGN_OR_RETURN(
+        direct_per_layer_decode_outputs
+            [EmbedderPerLayerSignatures::kEmbedderOutput],
+        direct_per_layer_compiled_model.CreateOutputBuffer(
+            "per_layer_embedder", "embeddings"));
+
+    EmbedderPerLayerContext direct_embedder_per_layer_context(
+        std::move(direct_per_layer_compiled_model),
+        std::move(direct_per_layer_prefill_inputs),
+        std::move(direct_per_layer_prefill_outputs),
+        std::move(direct_per_layer_decode_inputs),
+        std::move(direct_per_layer_decode_outputs));
+
+    SortedPrefillSignatureMap prefill_runner_set;
+    prefill_runner_set[kPrefillSize] = std::string(kPrefillSignature);
+    if (direct_prefill_1024_inference_context.has_value()) {
+      prefill_runner_set[kPrefill1024Size] =
+          std::string(kPrefill1024Signature);
+    }
+
+    std::unique_ptr<EmbeddingLookupManager> no_embedding_lookup_manager;
+    SpeculativeDecodingType direct_speculative_decoding_type =
+        SpeculativeDecodingType::kNone;
+    std::optional<DrafterContext> direct_drafter_context = std::nullopt;
+    if (Q6AEnvFlagEnabled("Q6A_OFFICIAL_MTP_NPU_HYBRID")) {
+      auto mtp_drafter_model =
+          resources.GetTFLiteModel(ModelType::kTfLiteMtpDrafter);
+      if (!mtp_drafter_model.ok()) {
+        ABSL_LOG(ERROR) << "Q6A_HYBRID_STEP_FAIL mtp_drafter_missing: "
+                        << mtp_drafter_model.status();
