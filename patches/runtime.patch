+absl::Status Q6AFillTokenIds(::litert::TensorBuffer& buffer,
+                             absl::Span<const int> ids) {
+  LITERT_ASSIGN_OR_RETURN(auto packed_size, buffer.PackedSize());
+  LITERT_ASSIGN_OR_RETURN(
+      auto lock_and_addr,
+      ::litert::TensorBufferScopedLock::Create(
+          buffer, ::litert::TensorBuffer::LockMode::kWrite));
+  std::memset(lock_and_addr.second, 0, packed_size);
+  auto* ptr = static_cast<int32_t*>(lock_and_addr.second);
+  const size_t n = std::min(ids.size(), packed_size / sizeof(int32_t));
+  for (size_t i = 0; i < n; ++i) {
+    ptr[i] = ids[i];
+  }
+  return absl::OkStatus();
+}
