+  if (limit <= 0) {
+    return absl::InvalidArgumentError(
+        absl::StrCat("No valid logits candidates. valid_vocab_size=",
+                     valid_vocab_size, " logits_size=", logits_buffer.size()));
+  }
+  int max_index = 0;
+  T max_value = std::numeric_limits<T>::lowest();
+  for (int i = 0; i < limit; ++i) {
+    if (logits_buffer[i] > max_value) {
+      max_value = logits_buffer[i];
+      max_index = i;
+    }
+  }
+  return max_index;
+}
