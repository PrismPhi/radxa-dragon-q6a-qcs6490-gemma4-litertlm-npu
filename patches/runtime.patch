+absl::Status Q6ACopyOneTokenBufferToPrefillSlot(
+    ::litert::TensorBuffer& src_one_token_buffer,
+    ::litert::TensorBuffer& dst_prefill_buffer, int slot_index) {
+  LITERT_ASSIGN_OR_RETURN(auto src_size, src_one_token_buffer.PackedSize());
+  LITERT_ASSIGN_OR_RETURN(auto dst_size, dst_prefill_buffer.PackedSize());
+
+  if ((slot_index + 1) * src_size > dst_size) {
+    return absl::InvalidArgumentError(
+        "Q6ACopyOneTokenBufferToPrefillSlot: slot out of range.");
+  }
+
+  LITERT_ASSIGN_OR_RETURN(
+      auto src_lock,
+      ::litert::TensorBufferScopedLock::Create(
+          src_one_token_buffer, ::litert::TensorBuffer::LockMode::kRead));
+  LITERT_ASSIGN_OR_RETURN(
+      auto dst_lock,
+      ::litert::TensorBufferScopedLock::Create(
+          dst_prefill_buffer, ::litert::TensorBuffer::LockMode::kWrite));
+
+  auto* dst = static_cast<char*>(dst_lock.second);
+  std::memcpy(dst + slot_index * src_size, src_lock.second, src_size);
+  return absl::OkStatus();
+}
