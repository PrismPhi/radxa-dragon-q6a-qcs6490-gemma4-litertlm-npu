+                          GetLogitsElementCount(decoded_logits));
+  const int valid_vocab_size = std::min(
+      logits_element_count,
+      Q6AEnvIntOrDefault("Q6A_GEMMA4_VALID_VOCAB_SIZE",
+                         kGemma4Ctx1024UnsafeTokenFloor));
+  const bool sample_trace = Q6AEnvFlagEnabled("Q6A_FINAL_SAMPLE_TRACE");
+  if (sample_trace) {
+    ABSL_LOG(ERROR) << "Q6A_FINAL_SAMPLE_ID_RAW sampled_id=" << sampled_id;
+    ABSL_LOG(ERROR) << "Q6A_FINAL_VALID_VOCAB_SIZE valid_vocab_size="
+                    << valid_vocab_size
+                    << " logits_elements=" << logits_element_count;
+  }
+  if (!Q6AEnvFlagEnabled("Q6A_GEMMA4_CTX1024_UNSAFE_TOKEN_GUARD") ||
+      max_num_tokens > kPrefill1024Size) {
+    if (sample_trace) {
+      ABSL_LOG(ERROR)
+          << "Q6A_FINAL_STOP_REASON token_policy_disabled_or_ctx4096";
+    }
+    return sampled_id;
+  }
+  if (sampled_id >= 0 && sampled_id < valid_vocab_size) {
+    if (sample_trace) {
+      ABSL_LOG(ERROR) << "Q6A_FINAL_STOP_REASON sampled_token_valid";
+    }
+    return sampled_id;
+  }
+
+  ABSL_LOG(ERROR) << "Q6A_FINAL_SAMPLE_ID_RAW sampled_id=" << sampled_id;
+  ABSL_LOG(ERROR) << "Q6A_FINAL_VALID_VOCAB_SIZE valid_vocab_size="
+                  << valid_vocab_size
+                  << " logits_elements=" << logits_element_count;
+  ABSL_LOG(ERROR) << "Q6A_FINAL_SAMPLE_ID_INVALID sampled_id=" << sampled_id
+                  << " valid_vocab_size=" << valid_vocab_size
+                  << " max_tokens=" << max_num_tokens;
+  ABSL_LOG(ERROR) << "Q6A_GEMMA4_CTX1024_UNSAFE_TOKEN_GUARD sampled_id="
+                  << sampled_id << " policy=resample max_tokens="
+                  << max_num_tokens;
+  ABSL_LOG(ERROR) << "Q6A_FINAL_UNSAFE_TOKEN_POLICY=resample";
+  LITERT_ASSIGN_OR_RETURN(
+      int resampled_id,
+      ApplyGreedySamplingWithinValidVocab(decoded_logits, valid_vocab_size));
+  if (resampled_id < 0 || resampled_id >= valid_vocab_size) {
+    ABSL_LOG(ERROR) << "Q6A_FINAL_STOP_REASON no_valid_resample_candidate";
+    return absl::InternalError(absl::StrCat(
+        "Resampled token is still invalid: ", resampled_id,
+        " valid_vocab_size=", valid_vocab_size));
+  }
+  ABSL_LOG(ERROR) << "Q6A_FINAL_SAMPLE_RESAMPLED before=" << sampled_id
+                  << " after=" << resampled_id;
+  ABSL_LOG(ERROR) << "Q6A_FINAL_STOP_REASON resampled_valid_token";
+  return resampled_id;
+}
