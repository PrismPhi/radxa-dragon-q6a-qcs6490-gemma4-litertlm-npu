+class Gemma4ModelContractValidator {
+ public:
+  static absl::Status Validate(const litert::Model* transformer_model) {
+    auto prefill_signature =
+        transformer_model->FindSignature(kPrefillSignature);
+    if (!prefill_signature) {
+      return absl::FailedPreconditionError(
+          "Gemma4 Direct requires prefill_128 signature.");
+    }
+    auto decode_signature = transformer_model->FindSignature(kDecodeSignature);
+    if (!decode_signature) {
+      return absl::FailedPreconditionError(
+          "Gemma4 Direct requires decode signature.");
+    }
+
+    auto validate_direct_inputs = [](const auto& signature) -> absl::Status {
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          signature, "embeddings", ::litert::ElementType::Float32));
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          signature, "per_layer_embeddings", ::litert::ElementType::Float32));
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          signature, "input_pos", ::litert::ElementType::Int32));
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          signature, "mask", ::litert::ElementType::Bool));
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          signature, "param_tensor", ::litert::ElementType::Int32));
+      return absl::OkStatus();
+    };
+    RETURN_IF_ERROR(validate_direct_inputs(*prefill_signature));
+    RETURN_IF_ERROR(validate_direct_inputs(*decode_signature));
+    RETURN_IF_ERROR(Q6ARequireOutputElementType(
+        *decode_signature, "logits",
+        ::litert::ElementType::Float32));
+
+    std::set<std::string> kv_names;
+    int key_cache_count = 0;
+    int value_cache_count = 0;
+    for (auto name : decode_signature->InputNames()) {
+      if (absl::StartsWith(name, kv_cache_k_root_name)) {
+        kv_names.insert(std::string(name));
+        ++key_cache_count;
+      } else if (absl::StartsWith(name, kv_cache_v_root_name)) {
+        kv_names.insert(std::string(name));
+        ++value_cache_count;
+      }
+    }
+    if (key_cache_count == 0 || key_cache_count != value_cache_count) {
+      return absl::FailedPreconditionError(
+          "Gemma4 Direct requires balanced kv_cache_k_* / kv_cache_v_* inputs.");
+    }
+
+    for (const std::string& name : kv_names) {
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          *prefill_signature, name, ::litert::ElementType::Int8));
+      RETURN_IF_ERROR(Q6ARequireOutputElementType(
+          *prefill_signature, name, ::litert::ElementType::Int8));
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          *decode_signature, name, ::litert::ElementType::Int8));
+      RETURN_IF_ERROR(Q6ARequireOutputElementType(
+          *decode_signature, name, ::litert::ElementType::Int8));
+      RETURN_IF_ERROR(
+          Q6AValidateCacheInputOutputContract(*prefill_signature, name));
+      RETURN_IF_ERROR(
+          Q6AValidateCacheInputOutputContract(*decode_signature, name));
+      RETURN_IF_ERROR(Q6AValidateMatchingInputContract(
+          *prefill_signature, *decode_signature, name));
+    }
+    return absl::OkStatus();
+  }
+};
