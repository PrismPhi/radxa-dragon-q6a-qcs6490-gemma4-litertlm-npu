+      direct_speculative_decoding_type = SpeculativeDecodingType::kMTP;
+      ABSL_LOG(ERROR) << "Q6A_HYBRID_LOOP_START init=1";
+      ABSL_LOG(ERROR) << "Q6A_OFFICIAL_MTP_DRAFTER_FOUND";
+    }
+
+    auto executor = absl::WrapUnique(new LlmLiteRtNpuCompiledModelExecutor(
+        std::move(direct_executor_settings), env,
+        /*embedder_context=*/std::optional<EmbedderContext>(std::move(direct_embedder_context)),
+        /*npu_auxiliary_context=*/std::nullopt,
+        /*mask_context=*/std::nullopt,
+        /*rope_context=*/std::nullopt,
+        std::move(llm_compiled_model),
+        std::move(llm_inference_context),
+        /*cache_update_inference_context=*/std::nullopt,
+        std::move(prefill_runner_set),
+        std::move(no_embedding_lookup_manager),
+        /*embedder_per_layer_context=*/std::optional<EmbedderPerLayerContext>(std::move(direct_embedder_per_layer_context)),
+        quantization_params,
+        direct_speculative_decoding_type,
+        /*drafter_context=*/std::move(direct_drafter_context),
+        /*drafter_aux_context=*/std::nullopt,
+        /*execution_plan=*/direct_execution_plan,
+        /*direct_prefill_1024_inference_context=*/
+            std::move(direct_prefill_1024_inference_context)));
+
+    return executor;
+  }
