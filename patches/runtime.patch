+      if (absl::StartsWith(name, kv_cache_k_root_name)) {
+        kv_names.insert(std::string(name));
+        ++key_cache_count;
+      } else if (absl::StartsWith(name, kv_cache_v_root_name)) {
+        kv_names.insert(std::string(name));
+        ++value_cache_count;
+      }
