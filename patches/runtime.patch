+absl::Status Q6ACopyTensorBuffer(::litert::TensorBuffer& src,
+                                 ::litert::TensorBuffer& dst) {
+  LITERT_ASSIGN_OR_RETURN(auto src_size, src.PackedSize());
+  LITERT_ASSIGN_OR_RETURN(auto dst_size, dst.PackedSize());
+  if (src_size != dst_size) {
+    return absl::InvalidArgumentError(absl::StrCat(
+        "Q6ACopyTensorBuffer: size mismatch src=", src_size,
+        " dst=", dst_size));
+  }
+
+  LITERT_ASSIGN_OR_RETURN(
+      auto src_lock,
+      ::litert::TensorBufferScopedLock::Create(
+          src, ::litert::TensorBuffer::LockMode::kRead));
+  LITERT_ASSIGN_OR_RETURN(
+      auto dst_lock,
+      ::litert::TensorBufferScopedLock::Create(
+          dst, ::litert::TensorBuffer::LockMode::kWrite));
+
+  std::memcpy(dst_lock.second, src_lock.second, src_size);
+  return absl::OkStatus();
+}
