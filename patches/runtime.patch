+    for (const std::string& name : kv_names) {
+      RETURN_IF_ERROR(Q6ARequireInputElementType(
+          *prefill_signature, name, ::litert::ElementType::Float32));
+      RETURN_IF_ERROR(Q6ARequireOutputElementType(
