+  auto* ptr = static_cast<int32_t*>(lock_and_addr.second);
+  const int64_t n =
+      std::min<int64_t>(steps, static_cast<int64_t>(num_elements));
+  for (int64_t i = 0; i < n; ++i) {
+    ptr[i] = start + i;
+  }
+  return absl::OkStatus();
+}
