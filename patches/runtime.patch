+      RETURN_IF_ERROR(
+          Q6AValidateCacheInputOutputContract(*prefill_signature, name));
+      RETURN_IF_ERROR(
+          Q6AValidateCacheInputOutputContract(*decode_signature, name));
+      RETURN_IF_ERROR(Q6AValidateMatchingInputContract(
