+bool IsGemma4DirectCandidate(const litert::Model* transformer_model) {
+  auto decode_signature = transformer_model->FindSignature(kDecodeSignature);
+  if (!decode_signature) {
+    return false;
+  }
+
+  const auto input_names = decode_signature->InputNames();
+  const auto output_names = decode_signature->OutputNames();
+
+  return ContainsSignatureName(input_names, "param_tensor") ||
+         ContainsSignatureName(output_names, "kv_cache_k_0") ||
+         ContainsSignatureName(output_names, "kv_cache_v_0");
+}
