+template <typename Signature>
+absl::Status Q6ARequireInputElementType(const Signature& signature,
+                                        absl::string_view name,
+                                        ::litert::ElementType element_type) {
+  if (!ContainsSignatureName(signature.InputNames(), name)) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("Gemma4 Direct missing input tensor: ", name));
+  }
+  LITERT_ASSIGN_OR_RETURN(auto tensor, signature.InputTensor(name));
+  LITERT_ASSIGN_OR_RETURN(auto tensor_type, tensor.RankedTensorType());
+  if (tensor_type.ElementType() != element_type) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("Gemma4 Direct input dtype mismatch: ", name));
+  }
+  return absl::OkStatus();
+}
+
+template <typename Signature>
+absl::Status Q6ARequireOutputElementType(const Signature& signature,
+                                         absl::string_view name,
+                                         ::litert::ElementType element_type) {
+  if (!ContainsSignatureName(signature.OutputNames(), name)) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("Gemma4 Direct missing output tensor: ", name));
+  }
+  LITERT_ASSIGN_OR_RETURN(auto tensor, signature.OutputTensor(name));
+  LITERT_ASSIGN_OR_RETURN(auto tensor_type, tensor.RankedTensorType());
+  if (tensor_type.ElementType() != element_type) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("Gemma4 Direct output dtype mismatch: ", name));
+  }
+  return absl::OkStatus();
+}
+
+bool Q6ASameTensorContract(const ::litert::RankedTensorType& lhs,
+                           const ::litert::RankedTensorType& rhs) {
+  const auto lhs_dims = lhs.Layout().Dimensions();
+  const auto rhs_dims = rhs.Layout().Dimensions();
+  return lhs.ElementType() == rhs.ElementType() &&
+         lhs_dims.size() == rhs_dims.size() &&
+         std::equal(lhs_dims.begin(), lhs_dims.end(), rhs_dims.begin());
+}
+
+template <typename Signature>
+absl::Status Q6AValidateCacheInputOutputContract(const Signature& signature,
+                                                 absl::string_view name) {
+  LITERT_ASSIGN_OR_RETURN(auto input_tensor, signature.InputTensor(name));
+  LITERT_ASSIGN_OR_RETURN(auto output_tensor, signature.OutputTensor(name));
+  LITERT_ASSIGN_OR_RETURN(auto input_type, input_tensor.RankedTensorType());
+  LITERT_ASSIGN_OR_RETURN(auto output_type, output_tensor.RankedTensorType());
+  if (!Q6ASameTensorContract(input_type, output_type)) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("Gemma4 Direct KV input/output mismatch: ", name));
+  }
+  return absl::OkStatus();
+}
+
+template <typename LeftSignature, typename RightSignature>
+absl::Status Q6AValidateMatchingInputContract(const LeftSignature& lhs,
+                                              const RightSignature& rhs,
+                                              absl::string_view name) {
+  LITERT_ASSIGN_OR_RETURN(auto lhs_tensor, lhs.InputTensor(name));
+  LITERT_ASSIGN_OR_RETURN(auto rhs_tensor, rhs.InputTensor(name));
+  LITERT_ASSIGN_OR_RETURN(auto lhs_type, lhs_tensor.RankedTensorType());
+  LITERT_ASSIGN_OR_RETURN(auto rhs_type, rhs_tensor.RankedTensorType());
+  if (!Q6ASameTensorContract(lhs_type, rhs_type)) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("Gemma4 Direct KV signature mismatch: ", name));
+  }
+  return absl::OkStatus();
+}
